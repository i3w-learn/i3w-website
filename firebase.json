{
  "hosting": {
    "site": "i3w-website",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/.*/**",
      "_assemble.py",
      "_template.html",
      "_parts/**",
      "README.md",
      "DESIGN-AUDIT-AND-SYSTEM.md"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
        ]
      }
    ],
    "cleanUrls": false,
    "trailingSlash": false
  }
}
